<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<!--
  ServerSetup.fxml — màn hình nhập địa chỉ server (hiện trước Login)
  Controller: com.example.controller.ServerSetupController
-->
<HBox prefHeight="720" prefWidth="1280"
      style="-fx-background-color: #FFFFFF;"
      stylesheets="@../css/style.css"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.controller.ServerSetupController">

    <!-- ── Left: branding / illustration area ───────────────────────── -->
    <VBox HBox.hgrow="ALWAYS" alignment="CENTER"
          style="-fx-background-color: #F5F5F5; -fx-padding: 60;">
        <Label text="🏷️" style="-fx-font-size: 80px;"/>
        <Region prefHeight="20"/>
        <Label text="AUCTION SYSTEM"
               style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #222;"/>
        <Region prefHeight="12"/>
        <Label text="Hệ thống đấu giá trực tuyến"
               style="-fx-font-size: 16px; -fx-text-fill: #666;"/>
        <Region prefHeight="40"/>

        <!-- Info box -->
        <VBox style="-fx-background-color: #E8F4FD; -fx-padding: 20; -fx-background-radius: 10;
                     -fx-max-width: 380;" spacing="8">
            <Label text="📡  Instructions for connecting ngrok"
                   style="-fx-font-weight: bold; -fx-font-size: 14px; -fx-text-fill: #1565C0;"/>
            <Label text="1. Run server (ServerMain.java)"
                   style="-fx-font-size: 12px; -fx-text-fill: #333; -fx-wrap-text: true;"/>
            <Label text="2. Mở 2 terminal chạy ngrok:"
                   style="-fx-font-size: 12px; -fx-text-fill: #333;"/>
            <Label text="   ngrok tcp 8888  →  copy host + port API"
                   style="-fx-font-size: 12px; -fx-text-fill: #555; -fx-font-family: monospace;"/>
            <Label text="   ngrok tcp 8889  →  copy host + port Push"
                   style="-fx-font-size: 12px; -fx-text-fill: #555; -fx-font-family: monospace;"/>
            <Label text="3. Paste it into the field on the right and click Connect."
                   style="-fx-font-size: 12px; -fx-text-fill: #333;"/>
        </VBox>
    </VBox>

    <!-- ── Right: setup form ────────────────────────────────────────── -->
    <VBox HBox.hgrow="ALWAYS" alignment="TOP_LEFT" spacing="0"
          style="-fx-padding: 80 80 0 60;">

        <Label text="Server connection setup"
               style="-fx-font-size: 30px; -fx-font-weight: bold; -fx-text-fill: #222;"/>

        <Region prefHeight="8"/>
        <Label text="Choose the connection mode that matches your environment."
               style="-fx-font-size: 14px; -fx-text-fill: #666;"/>

        <Region prefHeight="30"/>

        <!-- Radio buttons -->
        <VBox spacing="12">
            <RadioButton fx:id="localRadio" text="💻  Localhost — The server is running on this same machine."
                         styleClass="radio-option"
                         style="-fx-font-size: 14px;"
                         onAction="#handleLocalMode">
                <toggleGroup><ToggleGroup fx:id="modeGroup"/></toggleGroup>
            </RadioButton>
            <RadioButton fx:id="ngrokRadio" text="🌐  Ngrok / Internet — The server is running on another machine."
                         styleClass="radio-option"
                         style="-fx-font-size: 14px;"
                         toggleGroup="$modeGroup"
                         onAction="#handleNgrokMode"/>
        </VBox>

        <Region prefHeight="28"/>

        <!-- ── Ngrok fields (ẩn ở chế độ localhost) ── -->
        <VBox spacing="14">

            <!-- API Server -->
            <VBox spacing="6">
                <Label fx:id="apiHostLabel" text="API Server Host  (port 8888)"
                       style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #444;"/>
                <TextField fx:id="apiHostField" maxWidth="480" prefWidth="480"
                           promptText="vd: 0.tcp.ap.ngrok.io"
                           styleClass="text-field-rounded"
                           stylesheets="@../css/style.css"/>

                <Label fx:id="apiPortLabel" text="API Server Port"
                       style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #444;"/>
                <TextField fx:id="apiPortField" maxWidth="480" prefWidth="480"
                           promptText="vd: 12345"
                           styleClass="text-field-rounded"
                           stylesheets="@../css/style.css"/>
            </VBox>

            <Region prefHeight="4"/>

            <!-- Push Server -->
            <VBox spacing="6">
                <Label fx:id="pushHostLabel" text="Push Server Host  (port 8889)"
                       style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #444;"/>
                <TextField fx:id="pushHostField" maxWidth="480" prefWidth="480"
                           promptText="vd: 0.tcp.ap.ngrok.io"
                           styleClass="text-field-rounded"
                           stylesheets="@../css/style.css"/>

                <Label fx:id="pushPortLabel" text="Push Server Port"
                       style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #444;"/>
                <TextField fx:id="pushPortField" maxWidth="480" prefWidth="480"
                           promptText="vd: 67890"
                           styleClass="text-field-rounded"
                           stylesheets="@../css/style.css"/>
            </VBox>
        </VBox>

        <Region prefHeight="28"/>

        <!-- Status + Loading -->
        <HBox spacing="10" alignment="CENTER_LEFT">
            <ProgressIndicator fx:id="loadingIndicator" prefWidth="24" prefHeight="24"/>
            <Label fx:id="statusLabel" style="-fx-font-size: 13px;"/>
        </HBox>

        <Region prefHeight="16"/>

        <!-- Connect button -->
        <Button fx:id="connectBtn" text="Connect →"
                maxWidth="480" prefWidth="480" prefHeight="44"
                onAction="#handleConnect"
                styleClass="btn-primary"
                stylesheets="@../css/style.css"/>

        <Region prefHeight="16"/>

        <Label text="Configuration is automatically saved to the server.properties file."
               style="-fx-font-size: 11px; -fx-text-fill: #999; -fx-font-style: italic;"/>

    </VBox>
</HBox>
