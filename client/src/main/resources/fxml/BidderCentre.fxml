<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<VBox xmlns:fx="http://javafx.com/fxml/1" prefHeight="720" prefWidth="1280" style="-fx-background-color: #FFFFFF;"
      stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/26"
      fx:controller="com.example.controller.BidderCentreController">

    <HBox alignment="CENTER_LEFT" styleClass="nav-bar">
        <Button maxWidth="Infinity" onAction="#handleHome" styleClass="nav-tab" text="Home" HBox.hgrow="ALWAYS"/>
        <Button maxWidth="Infinity" onAction="#handleAuctions" styleClass="nav-tab" text="Auctions"
                HBox.hgrow="ALWAYS"/>
        <Button maxWidth="Infinity" styleClass="nav-tab-active" text="Bidder centre" HBox.hgrow="ALWAYS"/>
        <Button maxWidth="Infinity" onAction="#handleSettings" styleClass="nav-tab" text="Settings"
                HBox.hgrow="ALWAYS"/>
    </HBox>

    <HBox VBox.vgrow="ALWAYS">

        <!-- Sidebar -->
        <VBox spacing="4" style="-fx-min-width: 200px; -fx-pref-width: 200px;" styleClass="sidebar">
            <Button fx:id="btnGiaoDich" onAction="#handleShowGiaoDich" styleClass="sidebar-item-active"
                    text="Transaction management"/>
            <Region prefHeight="8"/>
            <Button fx:id="btnSanPhamDauGia" onAction="#handleShowSanPhamDauGia" prefWidth="175"
                    styleClass="sidebar-item" text="The product has been successfully auctioned." wrapText="true"/>
        </VBox>

        <!-- Content stack -->
        <StackPane fx:id="contentStack" HBox.hgrow="ALWAYS">

            <!-- View 1: Giao dịch -->
            <VBox fx:id="viewGiaoDich" spacing="10" style="-fx-padding: 20;">
                <TableView fx:id="giaoDichTable" styleClass="table-view" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colMa" prefWidth="80" text="Id"/>
                        <TableColumn fx:id="colPhien" prefWidth="120" text="Session"/>
                        <TableColumn fx:id="colSanPham" prefWidth="160" text="Product"/>
                        <TableColumn fx:id="colTinhTrang" prefWidth="260" text="Status"/>
                        <TableColumn fx:id="colThoiGian" prefWidth="120" text="Time"/>
                        <TableColumn fx:id="colBaoCao" prefWidth="200" text="Report"/>
                    </columns>
                </TableView>
            </VBox>

            <!-- View 2: Sản phẩm đã đấu giá thành công -->
            <VBox fx:id="viewSanPham" managed="false" style="-fx-padding: 20;" visible="false">
                <ScrollPane fitToWidth="true" style="-fx-background-color: transparent;" VBox.vgrow="ALWAYS">
                    <FlowPane fx:id="wonProductGrid" hgap="20"
                              style="-fx-padding: 4; -fx-background-color: transparent;" vgap="20"/>
                </ScrollPane>
            </VBox>

        </StackPane>
    </HBox>
</VBox>
