<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<!-- Screen 2.1: Home - Admin -->

<VBox prefHeight="720" prefWidth="1280" style="-fx-background-color: #FFFFFF;" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.controller.HomeAdminController">

    <!-- Navigation Bar -->
    <HBox alignment="CENTER_LEFT" styleClass="nav-bar">

        <HBox alignment="CENTER_LEFT" styleClass="nav-wrapper">

            <Button onAction="#handleHome" prefHeight="95" prefWidth="400" styleClass="tab-first" stylesheets="@../css/style.css" text="Home">
                <font>
                    <Font size="4.0" />
                </font></Button>

            <Button onAction="#handleAdminCentre" prefHeight="95" prefWidth="400" styleClass="tab-mid" stylesheets="@../css/style.css" text="Admin centre" />

            <Button onAction="#handleUserReport" prefHeight="95" prefWidth="400" styleClass="tab-mid" stylesheets="@../css/style.css" text="User's report" />

            <Button onAction="#handleSettings" prefHeight="95" prefWidth="400" styleClass="tab-last" stylesheets="@../css/style.css" text="Settings" />

        </HBox>
    </HBox>

    <!-- Content -->
    <VBox spacing="0" styleClass="content-area" VBox.vgrow="ALWAYS">

        <!-- Welcome heading -->
        <Label fx:id="welcomeLabel" style="-fx-font-size: 34px;" styleClass="welcome-title" stylesheets="@../css/style.css" text="CHÀO MỪNG  Admin @tên_người_dùng">
            <VBox.margin>
                <Insets left="40.0" right="20.0" top="40.0" />
            </VBox.margin></Label>

        <Region prefHeight="69.0" prefWidth="1280.0" />

        <!-- 3 Quick-access cards -->
        <HBox alignment="CENTER_LEFT" spacing="50">

            <!-- Card 1: Quản lý -->
            <VBox pickOnBounds="false" spacing="8.0" styleClass="home-card" stylesheets="@../css/style.css">
                <Label prefHeight="25.0" prefWidth="207.0" styleClass="window-dots" stylesheets="@../css/style.css" text="_ □ ×" HBox.hgrow="ALWAYS">
                    <VBox.margin>
                        <Insets />
                    </VBox.margin></Label>
                <Label styleClass="home-card-subtitle" stylesheets="@../css/style.css" text="quản lý" />
                <Label prefHeight="87.0" prefWidth="239.0" styleClass="home-card-title" stylesheets="@../css/style.css" text="PHIÊN ĐẤU GIÁ&#10;SẢN PHẨM&#10;NGƯỜI DÙNG" wrapText="true" />
                <HBox.margin>
                    <Insets left="30.0" />
                </HBox.margin>
            </VBox>

            <!-- Card 2: Giải quyết -->
            <VBox spacing="8" styleClass="home-card" stylesheets="@../css/style.css">
                <Label prefHeight="25.0" prefWidth="264.0" styleClass="window-dots" stylesheets="@../css/style.css" text="_ □ ×" />
                <Label styleClass="home-card-subtitle" stylesheets="@../css/style.css" text="giải quyết" />
                <Label prefWidth="173.0" styleClass="home-card-title" text="CÁC VẤN ĐỀ&#10;CỦA NGƯỜI DÙNG" wrapText="true" />
                <HBox.margin>
                    <Insets />
                </HBox.margin>
            </VBox>

            <!-- Card 3: Chỉnh sửa -->
            <VBox spacing="8" styleClass="home-card" stylesheets="@../css/style.css">
                <Label prefHeight="25.0" prefWidth="286.0" styleClass="window-dots" stylesheets="@../css/style.css" text="_ □ ×" />
                <Label styleClass="home-card-subtitle" stylesheets="@../css/style.css" text="chỉnh sửa" />
                <Label styleClass="home-card-title" text="THÔNG TIN&#10;TÀI KHOẢN" wrapText="true" />
            </VBox>

        </HBox>
    </VBox>
</VBox>
