<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<!-- Screen 2.1: Home - Admin -->
<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.example.controller.HomeAdminController"
      stylesheets="@../css/style.css"
      prefWidth="1280" prefHeight="720"
      style="-fx-background-color: #FFFFFF;">

    <HBox styleClass="nav-bar" alignment="CENTER_LEFT">
        <Button text="Home" styleClass="nav-tab-active"
                onAction="#handleHome"
                maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
        <Button text="Admin centre" styleClass="nav-tab"
                onAction="#handleAdminCentre"
                maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
        <Button text="User's report" styleClass="nav-tab"
                onAction="#handleUserReport"
                maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
        <Button text="Settings" styleClass="nav-tab"
                onAction="#handleSettings"
                maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
    </HBox>

    <VBox styleClass="content-area" VBox.vgrow="ALWAYS" spacing="0">

        <Label fx:id="welcomeLabel"
               text="CHÀO MỪNG  Admin @tên_người_dùng"
               styleClass="welcome-title"
               style="-fx-font-size: 34px;"/>

        <Region prefHeight="50"/>

        <HBox spacing="30" alignment="CENTER_LEFT">

            <VBox styleClass="home-card" spacing="8"
                  onMouseClicked="#handleAdminCentre"
                  prefWidth="300" prefHeight="160">
                <HBox alignment="CENTER_RIGHT">
                    <Label text="_ □ ×" styleClass="window-dots"/>
                </HBox>
                <Label text="quản lý" styleClass="home-card-subtitle"/>
                <Label text="PHIÊN ĐẤU GIÁ&#10;SẢN PHẨM&#10;NGƯỜI DÙNG"
                       styleClass="home-card-title" wrapText="true"/>
            </VBox>

            <VBox styleClass="home-card" spacing="8"
                  onMouseClicked="#handleUserReport"
                  prefWidth="300" prefHeight="160">
                <HBox alignment="CENTER_RIGHT">
                    <Label text="_ □ ×" styleClass="window-dots"/>
                </HBox>
                <Label text="giải quyết" styleClass="home-card-subtitle"/>
                <Label text="CÁC VẤN ĐỀ&#10;CỦA NGƯỜI DÙNG"
                       styleClass="home-card-title" wrapText="true"/>
            </VBox>

            <VBox styleClass="home-card" spacing="8"
                  onMouseClicked="#handleSettings"
                  prefWidth="300" prefHeight="160">
                <HBox alignment="CENTER_RIGHT">
                    <Label text="_ □ ×" styleClass="window-dots"/>
                </HBox>
                <Label text="chỉnh sửa" styleClass="home-card-subtitle"/>
                <Label text="THÔNG TIN&#10;TÀI KHOẢN"
                       styleClass="home-card-title" wrapText="true"/>
            </VBox>

        </HBox>
    </VBox>
</VBox>
