<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<VBox prefHeight="720" prefWidth="1280" style="-fx-background-color: #FFFFFF;" stylesheets="@../css/style.css"
      xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.controller.SettingsController">

    <!-- Nav - Bidder -->
    <HBox alignment="CENTER_LEFT" styleClass="nav-bar">
        <Button maxWidth="Infinity" onAction="#handleHome" styleClass="nav-tab" text="Home" HBox.hgrow="ALWAYS"/>
        <Button maxWidth="Infinity" onAction="#handleAuctions" styleClass="nav-tab" text="Auctions"
                HBox.hgrow="ALWAYS"/>
        <Button maxWidth="Infinity" onAction="#handleBidderCentre" styleClass="nav-tab" text="Bidder centre"
                HBox.hgrow="ALWAYS"/>
        <Button maxWidth="Infinity" styleClass="nav-tab-active" text="Settings" HBox.hgrow="ALWAYS"/>
    </HBox>

    <ScrollPane fitToWidth="true" style="-fx-padding: 0; -fx-background-color: transparent;" VBox.vgrow="ALWAYS">
        <VBox spacing="0" style="-fx-padding: 40 100 40 60;">

            <Label fx:id="accountTitleLabel" style="-fx-font-size: 18px; -fx-font-weight: bold;"
                   text="Your account @user_name"/>
            <Region prefHeight="12"/>
            <VBox maxWidth="440" spacing="8">
                <TextField fx:id="displayUsername" editable="false" promptText="Username"
                           style="-fx-text-fill: #888; -fx-background-color: #F8F8F8;" styleClass="text-field-rounded"/>
                <TextField fx:id="displayRole" editable="false" promptText="Role"
                           style="-fx-text-fill: #888; -fx-background-color: #F8F8F8;" styleClass="text-field-rounded"/>
            </VBox>

            <Region prefHeight="30"/>
            <Label style="-fx-font-size: 18px; -fx-font-weight: bold;" text="Change Username"/>
            <Region prefHeight="12"/>
            <VBox maxWidth="440" spacing="8">
                <TextField fx:id="newUsernameField" promptText="New Username" styleClass="text-field-rounded"/>
                <PasswordField fx:id="passwordForUsernameField" promptText="Password" styleClass="text-field-rounded"/>
                <HBox alignment="CENTER_RIGHT">
                    <Button onAction="#handleSaveUsername" styleClass="btn-primary" text="SAVE"/>
                </HBox>
            </VBox>

            <Region prefHeight="30"/>
            <Label style="-fx-font-size: 18px; -fx-font-weight: bold;" text="Change Password"/>
            <Region prefHeight="12"/>
            <VBox maxWidth="440" spacing="8">
                <PasswordField fx:id="oldPasswordField" promptText="Old Password" styleClass="text-field-rounded"/>
                <PasswordField fx:id="newPasswordField" promptText="New Password" styleClass="text-field-rounded"/>
                <HBox alignment="CENTER_RIGHT">
                    <Button onAction="#handleSavePassword" styleClass="btn-primary" text="SAVE"/>
                </HBox>
            </VBox>

            <Label fx:id="messageLabel" managed="false" style="-fx-font-size: 13px; -fx-padding: 10 0 0 0;"
                   visible="false"/>
        </VBox>
    </ScrollPane>

    <HBox alignment="CENTER_RIGHT" style="-fx-padding: 0 30 20 0;">
        <Button onAction="#handleLogout" styleClass="btn-secondary" text="LOG OUT"/>
    </HBox>
</VBox>
