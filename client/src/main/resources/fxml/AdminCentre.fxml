<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox prefHeight="720" prefWidth="1280" style="-fx-background-color: #FFFFFF;" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.controller.AdminCentreController">

    <HBox styleClass="nav-bar" alignment="CENTER_LEFT">
        <Button text="Home"          styleClass="nav-tab"
                maxWidth="Infinity"  HBox.hgrow="ALWAYS" onAction="#handleHome"/>
        <Button text="Admin centre"      styleClass="nav-tab-active"
                maxWidth="Infinity"  HBox.hgrow="ALWAYS" />
        <Button text="User's report" styleClass="nav-tab"
                maxWidth="Infinity"  HBox.hgrow="ALWAYS" onAction="#handleUserReport"/>
        <Button text="Settings"      styleClass="nav-tab"
                maxWidth="Infinity"  HBox.hgrow="ALWAYS" onAction="#handleSettings"/>
    </HBox>

    <HBox VBox.vgrow="ALWAYS">

        <!-- Sidebar -->
        <VBox styleClass="sidebar" spacing="4">
            <Button fx:id="btnNguoiDung" text="Người dùng" styleClass="sidebar-item-active" onAction="#handleShowNguoiDung"/>
            <Button fx:id="btnSanPham"   text="Sản phẩm"   styleClass="sidebar-item"        onAction="#handleShowSanPham"/>
            <Button fx:id="btnPhien"     text="Phiên"       styleClass="sidebar-item"        onAction="#handleShowPhien"/>
            <Button fx:id="btnGiaoDich"  text="Giao dịch"   styleClass="sidebar-item"        onAction="#handleShowGiaoDich"/>
        </VBox>

        <!-- Main panel -->
        <VBox HBox.hgrow="ALWAYS" style="-fx-padding: 20;">
            <TableView fx:id="dataTable" VBox.vgrow="ALWAYS" styleClass="table-view">
                <columns>
                    <TableColumn fx:id="colId"        text="ID"                prefWidth="80"/>
                    <TableColumn fx:id="colTen"       text="Tên"               prefWidth="180"/>
                    <TableColumn fx:id="colThongTin"  text="Các thông tin khác" prefWidth="300"/>
                    <TableColumn fx:id="colExtra"     text="....."             prefWidth="200"/>
                    <TableColumn fx:id="colTrangThai" text="Trạng thái"        prefWidth="160" visible="false"/>
                </columns>
            </TableView>

            <HBox alignment="CENTER_RIGHT" spacing="10" style="-fx-padding: 16 0 0 0;">
                <Button fx:id="btnBan"       text="BAN"   styleClass="btn-danger"   onAction="#handleBan"/>
                <Button fx:id="btnMakeAdmin" text="ADMIN" styleClass="btn-success"  onAction="#handleMakeAdmin"/>
                <Button fx:id="btnEdit"      text="EDIT"  styleClass="btn-secondary" onAction="#handleEdit" visible="false" managed="false"/>
                <Button fx:id="btnSave"      text="SAVE"  styleClass="btn-primary"  onAction="#handleSave"/>
            </HBox>
        </VBox>
    </HBox>
</VBox>
