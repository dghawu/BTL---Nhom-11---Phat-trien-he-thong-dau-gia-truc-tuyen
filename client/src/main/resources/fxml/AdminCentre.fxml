<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<VBox prefHeight="720" prefWidth="1280" style="-fx-background-color: #FFFFFF;" stylesheets="@../css/style.css"
      xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.controller.AdminCentreController">

    <HBox alignment="CENTER_LEFT" styleClass="nav-bar">
        <Button maxWidth="Infinity" onAction="#handleHome" styleClass="nav-tab" text="Home" HBox.hgrow="ALWAYS"/>
        <Button maxWidth="Infinity" styleClass="nav-tab-active" text="Admin centre" HBox.hgrow="ALWAYS"/>
        <Button maxWidth="Infinity" onAction="#handleUserReport" styleClass="nav-tab" text="User's report"
                HBox.hgrow="ALWAYS"/>
        <Button maxWidth="Infinity" onAction="#handleSettings" styleClass="nav-tab" text="Settings"
                HBox.hgrow="ALWAYS"/>
    </HBox>

    <HBox VBox.vgrow="ALWAYS">

        <!-- Sidebar -->
        <VBox spacing="4" styleClass="sidebar">
            <Button fx:id="btnNguoiDung" onAction="#handleShowNguoiDung" styleClass="sidebar-item-active" text="User"/>
            <Button fx:id="btnSanPham" onAction="#handleShowSanPham" styleClass="sidebar-item" text="Products"/>
            <Button fx:id="btnPhien" onAction="#handleShowPhien" styleClass="sidebar-item" text="Sessions"/>
            <Button fx:id="btnGiaoDich" onAction="#handleShowGiaoDich" styleClass="sidebar-item" text="Transactions"/>
        </VBox>

        <!-- Main panel -->
        <VBox style="-fx-padding: 20;" HBox.hgrow="ALWAYS">
            <!-- TableView không khai báo cột — controller thêm động -->
            <TableView fx:id="dataTable" styleClass="table-view" VBox.vgrow="ALWAYS">
                <placeholder><Label text="Không có dữ liệu."/></placeholder>
            </TableView>

            <HBox alignment="CENTER_RIGHT" spacing="10" style="-fx-padding: 16 0 0 0;">
                <Button fx:id="btnBan"       onAction="#handleBan"       styleClass="btn-danger"   text="BAN"   visible="false" managed="false"/>
                <Button fx:id="btnMakeAdmin" onAction="#handleMakeAdmin" styleClass="btn-success"  text="ADMIN" visible="false" managed="false"/>
            </HBox>
        </VBox>
    </HBox>
</VBox>
