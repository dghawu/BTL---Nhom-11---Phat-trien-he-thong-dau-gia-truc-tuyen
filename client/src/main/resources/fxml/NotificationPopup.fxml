<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<VBox alignment="TOP_LEFT" prefHeight="200" prefWidth="400"
      style="-fx-background-color: #FFFFFF;              -fx-border-color: #222222; -fx-border-width: 1.5px;              -fx-border-radius: 10px; -fx-background-radius: 10px;              -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 20, 0, 0, 4);"
      stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.controller.NotificationController">

    <!-- Window chrome -->
    <HBox alignment="CENTER_RIGHT"
          style="-fx-padding: 8 12 6 12;                  -fx-border-color: transparent transparent #EEEEEE transparent;                  -fx-border-width: 0 0 1px 0;">
        <Label onMouseClicked="#handleClose" style="-fx-font-size: 13px; -fx-text-fill: #AAAAAA; -fx-cursor: hand;"
               text="_ □ ×"/>
    </HBox>

    <!-- Body -->
    <VBox spacing="6" style="-fx-padding: 20 24 24 24;" VBox.vgrow="ALWAYS">
        <Label style="-fx-font-size: 13px; -fx-font-style: italic; -fx-text-fill: #666666;" text="Notification"/>
        <Label fx:id="messageLabel" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #111111;"
               text="NOTIFICATION" wrapText="true"/>
    </VBox>
</VBox>
