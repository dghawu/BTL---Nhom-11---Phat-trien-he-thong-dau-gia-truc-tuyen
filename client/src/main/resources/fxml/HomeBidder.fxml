<?xml version="1.0" encoding="UTF-8"?>


<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>


<VBox prefHeight="720" prefWidth="1280" style="-fx-background-color: #FFFFFF;" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.controller.HomeBidderController">


    <HBox alignment="CENTER_LEFT" styleClass="nav-bar">
        <Button maxWidth="Infinity" styleClass="nav-tab-active" text="Home" HBox.hgrow="ALWAYS" />
        <Button maxWidth="Infinity" onAction="#handleAuctions" styleClass="nav-tab" text="Auctions" HBox.hgrow="ALWAYS" />
        <Button maxWidth="Infinity" onAction="#handleBidderCentre" styleClass="nav-tab" text="Bidder Centre" HBox.hgrow="ALWAYS" />
        <Button maxWidth="Infinity" onAction="#handleSettings" styleClass="nav-tab" text="Settings" HBox.hgrow="ALWAYS" />
    </HBox>
    <VBox spacing="0" styleClass="content-area" VBox.vgrow="ALWAYS">


        <VBox spacing="0" styleClass="home-hero-block">


            <VBox.margin>
                <Insets left="60" right="60" top="48" />
            </VBox.margin>


            <HBox alignment="CENTER_LEFT" spacing="12">
                <Label styleClass="hero-welcome-plain" text="Welcome" />
                <Label fx:id="welcomeLabel"
                       styleClass="hero-welcome-italic"
                       text="" />
            </HBox>


            <HBox alignment="CENTER_LEFT" spacing="0">
                <Label styleClass="hero-to-plain" text="to " />


                <StackPane styleClass="hero-highlight-wrap">
                    <Label styleClass="hero-highlight-text"
                           text="Online Bidding Platform" />
                </StackPane>
            </HBox>


        </VBox>


        <Region prefHeight="48" />


        <HBox alignment="TOP_CENTER" fillHeight="false" spacing="100">


            <padding>
                <Insets left="60" right="60" />
            </padding>


            <!-- Card 1 -->
            <VBox maxHeight="320" maxWidth="320" onMouseClicked="#handleGoAuctions" prefHeight="320" prefWidth="320" styleClass="home-card-new">


                <Label styleClass="home-card-new-title" text="View Auction Sessions" wrapText="true" />


                <Separator styleClass="home-card-new-sep" />


                <Label styleClass="home-card-new-desc" text="Access our comprehensive marketplace to explore active bidding pools, monitor real-time listings, and track price fluctuations with dynamic live charts." wrapText="true" />


            </VBox>


            <!-- Card 2 -->
            <VBox maxHeight="320" maxWidth="320" onMouseClicked="#handleGoBidderCentre" prefHeight="320" prefWidth="320" styleClass="home-card-new">


                <Label styleClass="home-card-new-title" text="Your Transactions" wrapText="true" />


                <Separator styleClass="home-card-new-sep" />


                <Label styleClass="home-card-new-desc" text="Manage your bids, track auction progress, and view your transaction history." wrapText="true" />


            </VBox>


            <!-- Card 3 -->
            <VBox maxHeight="320" maxWidth="320" onMouseClicked="#handleGoSettings" prefHeight="320" prefWidth="320" styleClass="home-card-new">


                <Label styleClass="home-card-new-title" text="Account Settings" wrapText="true" />


                <Separator styleClass="home-card-new-sep" />


                <Label styleClass="home-card-new-desc" text="Update your profile information, security settings, and account preferences." wrapText="true" />


            </VBox>


        </HBox>
    </VBox>
</VBox>

