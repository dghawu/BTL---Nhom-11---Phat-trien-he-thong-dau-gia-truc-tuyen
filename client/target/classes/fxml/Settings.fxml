<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox prefHeight="720" prefWidth="1280" style="-fx-background-color: #FFFFFF;" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.controller.SettingsController">

    <HBox alignment="CENTER_LEFT" styleClass="nav-bar">
        <HBox alignment="CENTER_LEFT" styleClass="nav-wrapper">
            <Button onAction="#handleHome" prefHeight="95" prefWidth="400" styleClass="tab-mid" stylesheets="@../css/style.css" text="Home" />
            <!-- 2 tab giữa để trống, tab Settings active -->
            <Button prefHeight="95" prefWidth="400" styleClass="tab-mid" stylesheets="@../css/style.css" text="" disable="true" style="-fx-opacity:0;"/>
            <Button prefHeight="95" prefWidth="400" styleClass="tab-mid" stylesheets="@../css/style.css" text="" disable="true" style="-fx-opacity:0;"/>
            <Button prefHeight="95" prefWidth="400" styleClass="tab-first" stylesheets="@../css/style.css" text="Settings" />
        </HBox>
    </HBox>

    <ScrollPane VBox.vgrow="ALWAYS" fitToWidth="true" style="-fx-padding: 0; -fx-background-color: transparent;">
        <VBox style="-fx-padding: 40 100 40 60;" spacing="0">

            <Label fx:id="accountTitleLabel" text="Your account @tên_người dùng"
                   style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
            <Region prefHeight="12"/>

            <VBox spacing="8" maxWidth="440">
                <TextField fx:id="displayUsername" promptText="Username" styleClass="text-field-rounded"
                           editable="false" style="-fx-text-fill: #888; -fx-background-color: #F8F8F8;"/>
                <TextField fx:id="displayRole"     promptText="Role"     styleClass="text-field-rounded"
                           editable="false" style="-fx-text-fill: #888; -fx-background-color: #F8F8F8;"/>
                <TextField fx:id="displayTimeCreate" promptText="Time Create" styleClass="text-field-rounded"
                           editable="false" style="-fx-text-fill: #888; -fx-background-color: #F8F8F8;"/>
            </VBox>

            <Region prefHeight="30"/>
            <Label text="Change Username" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
            <Region prefHeight="12"/>
            <VBox spacing="8" maxWidth="440">
                <TextField fx:id="newUsernameField" promptText="New Username" styleClass="text-field-rounded"/>
                <PasswordField fx:id="passwordForUsernameField" promptText="Password" styleClass="text-field-rounded"/>
                <HBox alignment="CENTER_RIGHT">
                    <Button text="SAVE" styleClass="btn-primary" onAction="#handleSaveUsername"/>
                </HBox>
            </VBox>

            <Region prefHeight="30"/>
            <Label text="Change Password" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
            <Region prefHeight="12"/>
            <VBox spacing="8" maxWidth="440">
                <PasswordField fx:id="oldPasswordField" promptText="Old Password" styleClass="text-field-rounded"/>
                <PasswordField fx:id="newPasswordField" promptText="New Password" styleClass="text-field-rounded"/>
                <HBox alignment="CENTER_RIGHT">
                    <Button text="SAVE" styleClass="btn-primary" onAction="#handleSavePassword"/>
                </HBox>
            </VBox>

            <Label fx:id="messageLabel" style="-fx-font-size: 13px; -fx-padding: 10 0 0 0;"
                   visible="false" managed="false"/>
        </VBox>
    </ScrollPane>

    <HBox alignment="CENTER_RIGHT" style="-fx-padding: 0 30 20 0;">
        <Button text="LOG OUT" styleClass="btn-secondary" onAction="#handleLogout"/>
    </HBox>
</VBox>
