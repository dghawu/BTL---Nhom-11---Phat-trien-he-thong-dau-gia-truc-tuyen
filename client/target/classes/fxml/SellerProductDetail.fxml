<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<VBox prefHeight="720" prefWidth="1280" style="-fx-background-color: #FFFFFF;" stylesheets="@../css/style.css"
      xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.controller.SellerProductDetailController">

    <HBox alignment="CENTER_LEFT" styleClass="nav-bar">
        <Button maxWidth="Infinity" onAction="#handleHome" styleClass="nav-tab" text="Home" HBox.hgrow="ALWAYS"/>
        <Button maxWidth="Infinity" onAction="#handleAuctions" styleClass="nav-tab" text="Auctions"
                HBox.hgrow="ALWAYS"/>
        <Button maxWidth="Infinity" styleClass="nav-tab-active" text="Seller centre" HBox.hgrow="ALWAYS"/>
        <Button maxWidth="Infinity" onAction="#handleSettings" styleClass="nav-tab" text="Settings"
                HBox.hgrow="ALWAYS"/>
    </HBox>

    <HBox VBox.vgrow="ALWAYS">
        <VBox spacing="4" styleClass="sidebar">
            <Label styleClass="sidebar-section-title" text="Product management"/>
            <Button onAction="#handleThemSanPham" styleClass="sidebar-item" text="· Add new product"/>
            <Button onAction="#handleXemSanPham" styleClass="sidebar-item-active" text="· View all products"/>
            <Label styleClass="sidebar-section-title" text="Manage auction sessions"/>
            <Button onAction="#handleTaoPhien" styleClass="sidebar-item" text="· Create new session"/>
            <Button onAction="#handleXemPhien" styleClass="sidebar-item" text="· View all sessions"/>
            <Label styleClass="sidebar-section-title" text="Statistics"/>
        </VBox>

        <VBox styleClass="detail-panel" HBox.hgrow="ALWAYS">
            <Label maxWidth="Infinity" styleClass="detail-header" text="Detail"/>
            <Separator/>
            <Label style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-padding: 16 0 8 0;"
                   text="View product details"/>

            <GridPane hgap="20" style="-fx-padding: 0 20 0 0;" vgap="12">
                <columnConstraints>
                    <ColumnConstraints minWidth="120" prefWidth="140"/>
                    <ColumnConstraints hgrow="ALWAYS"/>
                </columnConstraints>
                <Label styleClass="detail-label" text="Name" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                <Label fx:id="lblTen" text="— — — — —" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                <Label styleClass="detail-label" text="ID" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                <Label fx:id="lblId" text="— — — — —" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                <Label styleClass="detail-label" text="Category" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                <Label fx:id="lblPhanLoai" text="— — — — —" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
                <Label styleClass="detail-label" text="Sale start date" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
                <Label fx:id="lblNgayMoBan" text="— — — — —" GridPane.columnIndex="1" GridPane.rowIndex="3"/>
                <Label styleClass="detail-label" text="Price" GridPane.columnIndex="0" GridPane.rowIndex="4"/>
                <Label fx:id="lblGia" text="— — — — —" GridPane.columnIndex="1" GridPane.rowIndex="4"/>
                <Label styleClass="detail-label" text="Description" GridPane.columnIndex="0" GridPane.rowIndex="5"/>
                <Label fx:id="lblMoTa" text="— — — — —" GridPane.columnIndex="1" GridPane.rowIndex="5"/>
                <Label styleClass="detail-label" text="Status" GridPane.columnIndex="0" GridPane.rowIndex="6"/>
                <Label fx:id="lblTinhTrang" text="— — — — —" GridPane.columnIndex="1" GridPane.rowIndex="6"/>
                <Label styleClass="detail-label" text="Image" GridPane.columnIndex="0" GridPane.rowIndex="7"/>
                <rowConstraints>
                    <RowConstraints/>
                    <RowConstraints/>
                    <RowConstraints/>
                    <RowConstraints/>
                    <RowConstraints/>
                    <RowConstraints/>
                    <RowConstraints/>
                    <RowConstraints/>
                </rowConstraints>
            </GridPane>


            <Label styleClass="detail-label" text="Product Attributes" GridPane.columnIndex="0" GridPane.rowIndex="6"/>
            <VBox fx:id="attributesContainer" spacing="6" GridPane.columnIndex="1" GridPane.rowIndex="6"/>

            <HBox style="-fx-padding: 8 0 0 140;">
                <VBox>
                    <Pane fx:id="imgPane" prefHeight="160" prefWidth="180" styleClass="image-placeholder"/>
                    <Button fx:id="btnChooseImage" onAction="#handleChooseNewImage" styleClass="btn-secondary"
                            text="Chọn ảnh khác" style="-fx-margin: 8 0 0 0;" visible="false"/>
                </VBox>
            </HBox>

            <Region VBox.vgrow="ALWAYS"/>
            <HBox alignment="CENTER_RIGHT" spacing="12" style="-fx-padding: 0 20 16 0;">
                <Button onAction="#handleEdit" styleClass="btn-secondary" text="EDIT"/>
                <Button onAction="#handleSave" styleClass="btn-primary" text="SAVE"/>
            </HBox>
        </VBox>
    </HBox>
</VBox>
