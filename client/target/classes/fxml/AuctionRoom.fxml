<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<!--
  Screen 9.1.2: Thông tin chi tiết phiên đấu giá (Popup/Dialog)
  Load bằng: Stage dialog = new Stage(); dialog.initModality(Modality.APPLICATION_MODAL);
-->
<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.example.controller.AuctionDetailDialogController"
      stylesheets="@../css/style.css"
      prefWidth="900" prefHeight="560"
      style="-fx-background-color: #FFFFFF; -fx-background-radius: 16px;
             -fx-border-radius: 16px; -fx-padding: 36 40 30 40;
             -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.18), 30, 0, 0, 6);">

    <!-- Title -->
    <Label text="THÔNG TIN CHI TIẾT PHIÊN ĐẤU GIÁ"
           style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-alignment: CENTER;"
           maxWidth="Infinity" alignment="CENTER"/>

    <Region prefHeight="20"/>

    <!-- Content: info left + image right -->
    <HBox spacing="40" VBox.vgrow="ALWAYS">

        <!-- Left: fields -->
        <VBox spacing="10" HBox.hgrow="ALWAYS">

            <!-- Product info -->
            <GridPane hgap="16" vgap="8">
                <columnConstraints>
                    <ColumnConstraints minWidth="140" prefWidth="160"/>
                    <ColumnConstraints hgrow="ALWAYS"/>
                </columnConstraints>

                <Label text="Tên sản phẩm:" styleClass="detail-label" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                <Label fx:id="lblTenSP" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                <Label text="Id sản phẩm:" styleClass="detail-label" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                <Label fx:id="lblIdSP" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                <Label text="Mô tả:" styleClass="detail-label" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                <Label fx:id="lblMoTa" wrapText="true" GridPane.rowIndex="2" GridPane.columnIndex="1"/>
            </GridPane>

            <Separator style="-fx-padding: 4 0 4 0;"/>

            <!-- Session info -->
            <GridPane hgap="16" vgap="8">
                <columnConstraints>
                    <ColumnConstraints minWidth="140" prefWidth="160"/>
                    <ColumnConstraints hgrow="ALWAYS"/>
                </columnConstraints>

                <Label text="Id phiên:" styleClass="detail-label" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                <Label fx:id="lblIdPhien" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                <Label text="Thời gian mở phiên:" styleClass="detail-label" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                <Label fx:id="lblThoiGianMo" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                <Label text="Thời gian đóng phiên:" styleClass="detail-label" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                <Label fx:id="lblThoiGianDong" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

                <Label text="Giá khởi bán:" styleClass="detail-label" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                <Label fx:id="lblGiaKhoiBan" GridPane.rowIndex="3" GridPane.columnIndex="1"/>

                <Label text="Bước giá:" styleClass="detail-label" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
                <Label fx:id="lblBuocGia" GridPane.rowIndex="4" GridPane.columnIndex="1"/>
            </GridPane>

            <Separator style="-fx-padding: 4 0 4 0;"/>

            <!-- Seller info -->
            <GridPane hgap="16" vgap="8">
                <columnConstraints>
                    <ColumnConstraints minWidth="140" prefWidth="160"/>
                    <ColumnConstraints hgrow="ALWAYS"/>
                </columnConstraints>

                <Label text="Id người bán:" styleClass="detail-label" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                <Label fx:id="lblIdNguoiBan" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                <Label text="Phân loại:" styleClass="detail-label" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                <Label fx:id="lblPhanLoai" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                <Label text="Mô tả:" styleClass="detail-label" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                <Label fx:id="lblMoTa2" GridPane.rowIndex="2" GridPane.columnIndex="1"/>
            </GridPane>

        </VBox>

        <!-- Right: product image -->
        <Pane styleClass="image-placeholder"
              fx:id="imgPane"
              prefWidth="260" minWidth="220"
              style="-fx-background-color: #F8F8F8;"/>

    </HBox>

    <Region prefHeight="20"/>

    <!-- Action buttons -->
    <HBox alignment="CENTER" spacing="16">
        <Button text="ĐẤU GIÁ"
                styleClass="btn-primary"
                prefWidth="160"
                onAction="#handleDauGia"/>
        <Button text="QUAY LẠI"
                styleClass="btn-secondary"
                prefWidth="140"
                onAction="#handleClose"/>
        <Button text="ADD TO WATCH LIST"
                styleClass="btn-primary"
                prefWidth="200"
                onAction="#handleAddToWatchList"/>
    </HBox>

</VBox>
