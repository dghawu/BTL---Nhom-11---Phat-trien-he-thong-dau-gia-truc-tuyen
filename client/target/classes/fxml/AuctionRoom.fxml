<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="720" prefWidth="1280"
      style="-fx-background-color: #FFFFFF;"
      stylesheets="@../css/style.css"
      xmlns="http://javafx.com/javafx/26"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.controller.AuctionRoomController">

    <!-- ── NAV BAR ── -->
    <HBox alignment="CENTER_LEFT" styleClass="nav-bar">
        <Button maxWidth="Infinity" onAction="#handleHome"         styleClass="nav-tab"        text="Home"          HBox.hgrow="ALWAYS"/>
        <Button maxWidth="Infinity"                                styleClass="nav-tab-active" text="Auctions"       HBox.hgrow="ALWAYS"/>
        <Button maxWidth="Infinity" onAction="#handleBidderCentre" styleClass="nav-tab"        text="Bidder Centre" HBox.hgrow="ALWAYS"/>
        <Button maxWidth="Infinity" onAction="#handleSettings"     styleClass="nav-tab"        text="Settings"      HBox.hgrow="ALWAYS"/>
    </HBox>

    <!-- ── BACK LINK ── -->
    <HBox style="-fx-padding: 8 16 6 16;">
        <Label onMouseClicked="#handleBack" styleClass="auction-back-link" text="▶ Return to session list"/>
    </HBox>

    <!-- ── MAIN 3-COLUMN LAYOUT ── -->
    <HBox spacing="12" VBox.vgrow="ALWAYS" style="-fx-padding: 0 14 14 14;">

        <!-- ══ LEFT: Details ══ -->
        <VBox styleClass="auction-box-blue" style="-fx-pref-width: 280px; -fx-min-width: 260px;">
            <Label styleClass="auction-box-title" text="Details" maxWidth="Infinity"/>
            <HBox style="-fx-padding: 0 16 0 16;">
                <Region styleClass="auction-inner-sep" maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
            </HBox>
            <Pane fx:id="imgPane" styleClass="auction-img-pane" VBox.vgrow="ALWAYS"/>
            <HBox style="-fx-padding: 0 16 0 16;">
                <Region styleClass="auction-inner-sep" maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
            </HBox>
            <VBox spacing="5" style="-fx-padding: 10 14 12 14;">
                <Label fx:id="lblTenSP"           styleClass="auction-detail-text" text="Product name:"  wrapText="true"/>
                <Label fx:id="lblIdSP"            styleClass="auction-detail-text" text="Product id:"    wrapText="true"/>
                <Label fx:id="lblGiaMoBan"        styleClass="auction-detail-text" text="Starting price:"/>
                <Label fx:id="lblTinhTrang"       styleClass="auction-detail-text" text="Status:"/>
                <Label fx:id="lblMoTa"            styleClass="auction-detail-text" text="Description:"  wrapText="true"/>
                <VBox fx:id="attributesContainer" spacing="4" style="-fx-padding: 6 0 0 0;"/>
            </VBox>
        </VBox>

        <!-- ══ MIDDLE: Feed / Chart ══ -->
        <VBox styleClass="auction-box-white" HBox.hgrow="ALWAYS" spacing="0">
            <HBox alignment="CENTER" spacing="0" style="-fx-padding: 16 20 0 20;">
                <!-- Tab Feed -->
                <VBox alignment="CENTER" spacing="4" style="-fx-cursor: hand;" onMouseClicked="#handleTabFeed" HBox.hgrow="ALWAYS">
                    <Label fx:id="lblProductName" styleClass="auction-tab-label-active" text="History Bid"
                           maxWidth="Infinity" style="-fx-alignment: CENTER;"/>
                    <HBox style="-fx-padding: 0 20 0 20;">
                        <Region fx:id="tabFeedUnderline" styleClass="auction-tab-underline"
                                prefHeight="3" maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
                    </HBox>
                </VBox>

                <!-- Gạch chéo phân cách -->
                <Label text="/" style="-fx-font-size: 28px; -fx-text-fill: #aaaaaa; -fx-padding: 0 4 8 4;"/>

                <!-- Tab Chart -->
                <VBox alignment="CENTER" spacing="4" style="-fx-cursor: hand;" onMouseClicked="#handleTabChart" HBox.hgrow="ALWAYS">
                    <Label styleClass="auction-tab-label" text="Price Chart"
                           maxWidth="Infinity" style="-fx-alignment: CENTER;"/>
                    <HBox style="-fx-padding: 0 20 0 20;">
                        <Region fx:id="tabChartUnderline" styleClass="auction-tab-underline-inactive"
                                prefHeight="3" maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
                    </HBox>
                </VBox>
            </HBox>
            <Button fx:id="btnTabFeed"  visible="false" managed="false" onAction="#handleTabFeed"/>
            <Button fx:id="btnTabChart" visible="false" managed="false" onAction="#handleTabChart"/>
            <StackPane VBox.vgrow="ALWAYS" style="-fx-padding: 12 16 16 16;">
                <ScrollPane fx:id="scrollFeed" fitToWidth="true"
                            style="-fx-background-color: transparent; -fx-border-color: transparent;">
                    <VBox fx:id="bidHistoryBox" spacing="8"
                          style="-fx-padding: 4 0 4 0; -fx-background-color: transparent;"/>
                </ScrollPane>
                <VBox fx:id="chartPane" visible="false" managed="false"
                      style="-fx-background-color: transparent;"/>
            </StackPane>
        </VBox>

        <!-- ══ RIGHT: Timer + Bid ══ -->
        <VBox spacing="10" style="-fx-pref-width: 420px; -fx-min-width: 320px;">

            <!-- Blue box: Timer + Price -->
            <VBox styleClass="auction-box-blue" spacing="0">
                <GridPane>
                    <columnConstraints>
                        <ColumnConstraints prefWidth="200" minWidth="180"/>
                        <ColumnConstraints hgrow="ALWAYS"/>
                    </columnConstraints>
                    <rowConstraints>
                        <RowConstraints minHeight="90"/>  <!-- row 0: countdown + time -->
                        <RowConstraints minHeight="4"/>   <!-- row 1: đường kẻ -->
                        <RowConstraints minHeight="80"/>  <!-- row 2: info + price -->
                        <RowConstraints minHeight="4"/>   <!-- row 3: đường kẻ -->
                        <RowConstraints minHeight="34"/>  <!-- row 4: current winner -->
                    </rowConstraints>

                    <!-- Row 0: Countdown -->
                    <VBox alignment="CENTER" style="-fx-padding: 14 16 14 20;"
                          GridPane.columnIndex="0" GridPane.rowIndex="0">
                        <Label fx:id="lblThoiGianConLai" styleClass="auction-countdown" text="00:00:00"/>
                    </VBox>

                    <!-- Row 0: Opening / Closing time -->
                    <VBox alignment="CENTER_LEFT" spacing="4"
                          style="-fx-padding: 14 16 14 16;"
                          GridPane.columnIndex="1" GridPane.rowIndex="0">
                        <Label fx:id="lblThoiGianBatDau"  styleClass="auction-time-label" text="Opening time:"/>
                        <Label fx:id="lblThoiGianKetThuc" styleClass="auction-time-label" text="Closing time:"/>
                    </VBox>

                    <!-- Row 1: đường kẻ ngang -->
                    <HBox style="-fx-padding: 0 16 0 16;"
                          GridPane.columnIndex="0" GridPane.rowIndex="1"
                          GridPane.columnSpan="2">
                        <Region styleClass="auction-inner-sep" maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
                    </HBox>

                    <!-- Row 2: Starting price + Bid increment -->
                    <GridPane hgap="8" vgap="4" style="-fx-padding: 12 16 12 20;"
                              GridPane.columnIndex="0" GridPane.rowIndex="2">
                        <columnConstraints>
                            <ColumnConstraints prefWidth="105"/>
                            <ColumnConstraints prefWidth="80" hgrow="ALWAYS"/>
                        </columnConstraints>
                        <rowConstraints>
                            <RowConstraints/>
                            <RowConstraints/>
                        </rowConstraints>
                        <Label styleClass="auction-info-label" text="Starting price:"
                               GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                        <Label fx:id="lblGiaKhoiDiem" styleClass="auction-info-value" text="—"
                               GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                        <Label styleClass="auction-info-label" text="Bid increment:"
                               GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                        <Label fx:id="lblBuocGia" styleClass="auction-info-value" text="—"
                               GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                    </GridPane>

                    <!-- Row 2: Current price lớn -->
                    <VBox alignment="CENTER" style="-fx-padding: 12 16 12 16;"
                          GridPane.columnIndex="1" GridPane.rowIndex="2">
                        <Label fx:id="lblGiaHienTai" styleClass="auction-current-price" text="—"/>
                    </VBox>

                    <!-- Row 3: đường kẻ ngang -->
                    <HBox style="-fx-padding: 0 16 0 16;"
                          GridPane.columnIndex="0" GridPane.rowIndex="3"
                          GridPane.columnSpan="2">
                        <Region styleClass="auction-inner-sep" maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
                    </HBox>

                    <!-- Row 4: Current winner full width -->
                    <Label fx:id="lblNguoiGiuGia" styleClass="auction-winner-label"
                           text="Current winner: —"
                           style="-fx-padding: 6 20 10 20; -fx-font-weight: bold;"
                           GridPane.columnIndex="0" GridPane.rowIndex="4"
                           GridPane.columnSpan="2"/>

                </GridPane>
            </VBox>

            <!-- box: Bid actions -->
            <VBox styleClass="auction-box-blue" VBox.vgrow="ALWAYS" spacing="0">

                <!-- Manual Auction -->
                <VBox style="-fx-padding: 16 16 12 16;" spacing="10">
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Label styleClass="auction-bid-section-title" text="Manual Auction"/>
                        <Label fx:id="lblManualToggle" onMouseClicked="#handleToggleManual"
                               styleClass="auction-toggle-on" text="ON"/>
                    </HBox>
                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <TextField fx:id="manualBidField" promptText="Enter your bid"
                                   styleClass="text-field-rounded" HBox.hgrow="ALWAYS"/>
                        <Button onAction="#handleManualBid" styleClass="btn-dephon" text="SUBMIT"/>
                    </HBox>
                </VBox>

                <!-- Automatic Bidding -->
                <VBox style="-fx-padding: 4 16 16 16;" spacing="10">
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Label styleClass="auction-bid-section-title" text="Automatic Bidding"/>
                        <Label fx:id="lblAutoToggle" onMouseClicked="#handleToggleAuto"
                               styleClass="auction-toggle-off" text="OFF"/>
                    </HBox>
                    <TextField fx:id="autoBuocGiaField" disable="true"
                               promptText="Enter the automatic bid increment"
                               styleClass="text-field-rounded"/>
                    <TextField fx:id="autoMaxGiaField" disable="true"
                               promptText="Enter your maximum bid"
                               styleClass="text-field-rounded"/>
                    <HBox alignment="CENTER_RIGHT">
                        <Button onAction="#handleSaveAutoConfig" styleClass="btn-dephon" text="SAVE"/>
                    </HBox>
                </VBox>

                <Region VBox.vgrow="ALWAYS"/>

                <HBox alignment="CENTER_RIGHT" style="-fx-padding: 0 16 12 16;">
                    <Button onAction="#handleReport" styleClass="auction-report-btn" text="Report an issue"/>
                </HBox>
            </VBox>

        </VBox>
    </HBox>
</VBox>
