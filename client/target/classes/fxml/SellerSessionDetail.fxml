<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox prefHeight="720" prefWidth="1280" style="-fx-background-color: #FFFFFF;" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.controller.SellerSessionDetailController">

    <HBox styleClass="nav-bar" alignment="CENTER_LEFT">
        <Button text="Home"          styleClass="nav-tab"
                maxWidth="Infinity"  HBox.hgrow="ALWAYS" onAction="#handleHome"/>
        <Button text="Auctions"      styleClass="nav-tab"
                maxWidth="Infinity"  HBox.hgrow="ALWAYS" onAction="#handleAuctions"/>
        <Button text="Seller centre" styleClass="nav-tab-active"
                maxWidth="Infinity"  HBox.hgrow="ALWAYS" onAction="#handleSellerCentre"/>
        <Button text="Settings"      styleClass="nav-tab"
                maxWidth="Infinity"  HBox.hgrow="ALWAYS" onAction="#handleSettings"/>
    </HBox>

    <HBox VBox.vgrow="ALWAYS">
        <VBox styleClass="sidebar" spacing="4">
            <Label text="Quản lý sản phẩm" styleClass="sidebar-section-title"/>
            <Button text="· Thêm sản phẩm"       styleClass="sidebar-item" onAction="#handleThemSanPham"/>
            <Button text="· Xem tất cả sản phẩm" styleClass="sidebar-item" onAction="#handleXemSanPham"/>
            <Label text="Quản phiên đấu giá" styleClass="sidebar-section-title"/>
            <Button text="· Tạo phiên mới"    styleClass="sidebar-item"        onAction="#handleTaoPhien"/>
            <Button text="· Xem tất cả phiên" styleClass="sidebar-item-active" onAction="#handleXemPhien"/>
            <Label text="Thống kê..." styleClass="sidebar-section-title"/>
        </VBox>

        <VBox HBox.hgrow="ALWAYS" styleClass="detail-panel">
            <Label text="Chi tiết" styleClass="detail-header" maxWidth="Infinity"/>
            <Separator/>
            <Label text="Xem chi tiết phiên" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-padding: 16 0 8 0;"/>

            <GridPane hgap="20" vgap="10" style="-fx-padding: 0 20 0 0;">
                <columnConstraints>
                    <ColumnConstraints minWidth="160" prefWidth="180"/>
                    <ColumnConstraints hgrow="ALWAYS"/>
                </columnConstraints>
                <Label text="ID Phiên"       styleClass="detail-label" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                <Label fx:id="lblSessionId"  text="— — — — —"           GridPane.rowIndex="0" GridPane.columnIndex="1"/>
                <Label text="Tên sản phẩm"  styleClass="detail-label" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                <Label fx:id="lblTenSP"      text="— — — — —"           GridPane.rowIndex="1" GridPane.columnIndex="1"/>
                <Label text="Thời gian mở"  styleClass="detail-label" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                <Label fx:id="lblThoiGianMo" text="— — — — —"           GridPane.rowIndex="2" GridPane.columnIndex="1"/>
                <Label text="Thời gian đóng" styleClass="detail-label" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                <Label fx:id="lblThoiGianDong" text="— — — — —"         GridPane.rowIndex="3" GridPane.columnIndex="1"/>
                <Label text="Giá khởi điểm" styleClass="detail-label" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
                <Label fx:id="lblGiaKhoiDiem" text="— — — — —"          GridPane.rowIndex="4" GridPane.columnIndex="1"/>
                <Label text="Bước giá"       styleClass="detail-label" GridPane.rowIndex="5" GridPane.columnIndex="0"/>
                <Label fx:id="lblBuocGia"    text="— — — — —"           GridPane.rowIndex="5" GridPane.columnIndex="1"/>
                <Label text="Trạng thái"     styleClass="detail-label" GridPane.rowIndex="6" GridPane.columnIndex="0"/>
                <Label fx:id="lblTrangThai"  text="— — — — —"           GridPane.rowIndex="6" GridPane.columnIndex="1"/>
            </GridPane>

            <HBox style="-fx-padding: 0 0 0 0;">
                <Pane styleClass="image-placeholder" fx:id="imgPane" prefWidth="180" prefHeight="160"/>
            </HBox>

            <Region VBox.vgrow="ALWAYS"/>
            <HBox alignment="CENTER_RIGHT" spacing="12" style="-fx-padding: 0 20 16 0;">
                <Button text="EDIT" styleClass="btn-secondary" onAction="#handleEdit"/>
                <Button text="SAVE" styleClass="btn-primary"   onAction="#handleSave"/>
            </HBox>
        </VBox>
    </HBox>
</VBox>
