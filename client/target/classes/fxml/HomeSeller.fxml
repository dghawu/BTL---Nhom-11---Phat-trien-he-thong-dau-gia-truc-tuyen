<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="720" prefWidth="1280" style="-fx-background-color: #FFFFFF;" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.controller.HomeSellerController">

    <HBox styleClass="nav-bar" alignment="CENTER_LEFT">
        <Button text="Home"          styleClass="nav-tab-active"
                maxWidth="Infinity"  HBox.hgrow="ALWAYS" onAction="#handleHome"/>
        <Button text="Auctions"      styleClass="nav-tab"
                maxWidth="Infinity"  HBox.hgrow="ALWAYS" onAction="#handleAuctions"/>
        <Button text="Seller centre" styleClass="nav-tab"
                maxWidth="Infinity"  HBox.hgrow="ALWAYS" onAction="#handleSellerCentre"/>
        <Button text="Settings"      styleClass="nav-tab"
                maxWidth="Infinity"  HBox.hgrow="ALWAYS" onAction="#handleSettings"/>
    </HBox>

    <VBox spacing="0" styleClass="content-area" VBox.vgrow="ALWAYS">

        <Label fx:id="welcomeLabel" style="-fx-font-size: 32px;" styleClass="welcome-title"
               text="CHÀO MỪNG Seller @tên_người_dùng&#10;ĐẾN VỚI ABCXYZ" wrapText="true">
            <VBox.margin><Insets left="40.0" right="20.0" top="40.0" /></VBox.margin>
        </Label>

        <Region prefHeight="69.0" prefWidth="1280.0" />

        <HBox alignment="CENTER_LEFT" spacing="50">

            <VBox spacing="8.0" styleClass="home-card" onMouseClicked="#handleGoAuctions">
                <Label prefHeight="25.0" prefWidth="207.0" styleClass="window-dots" text="_ □ ×" />
                <Label styleClass="home-card-subtitle" text="xem ngay" />
                <Label styleClass="home-card-title" text="CÁC PHIÊN&#10;ĐẤU GIÁ" wrapText="true" />
                <HBox.margin><Insets left="30.0" /></HBox.margin>
            </VBox>

            <VBox spacing="8" styleClass="home-card" onMouseClicked="#handleGoSellerCentre">
                <Label prefHeight="25.0" prefWidth="264.0" styleClass="window-dots" text="_ □ ×" />
                <Label styleClass="home-card-subtitle" text="quản lý" />
                <Label styleClass="home-card-title" text="PHIÊN ĐẤU GIÁ,&#10;SẢN PHẨM" wrapText="true" />
            </VBox>

            <VBox spacing="8" styleClass="home-card" onMouseClicked="#handleGoSettings">
                <Label prefHeight="25.0" prefWidth="286.0" styleClass="window-dots" text="_ □ ×" />
                <Label styleClass="home-card-subtitle" text="chỉnh sửa" />
                <Label styleClass="home-card-title" text="THÔNG TIN&#10;TÀI KHOẢN" wrapText="true" />
            </VBox>

        </HBox>
    </VBox>
</VBox>
