<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="720" prefWidth="1280" style="-fx-background-color: #FFFFFF;" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.controller.SellerCreateSessionController">

    <HBox alignment="CENTER_LEFT" styleClass="nav-bar">
        <Button maxWidth="Infinity" onAction="#handleHome" styleClass="nav-tab" text="Home" HBox.hgrow="ALWAYS" />
        <Button maxWidth="Infinity" onAction="#handleAuctions" styleClass="nav-tab" text="Auctions" HBox.hgrow="ALWAYS" />
        <Button maxWidth="Infinity" styleClass="nav-tab-active" text="Seller centre" HBox.hgrow="ALWAYS" />
        <Button maxWidth="Infinity" onAction="#handleSettings" styleClass="nav-tab" text="Settings" HBox.hgrow="ALWAYS" />
    </HBox>

    <HBox VBox.vgrow="ALWAYS">
        <VBox spacing="4" styleClass="sidebar">
            <Label styleClass="sidebar-section-title" text="Product management" />
            <Button onAction="#handleThemSanPham" styleClass="sidebar-item" text="· Add new product" />
            <Button onAction="#handleXemSanPham" styleClass="sidebar-item" text="· View all products" />
            <Label styleClass="sidebar-section-title" text="Manage auction sessions " />
            <Button onAction="#handleTaoPhien" styleClass="sidebar-item-active" text="· Create new session" />
            <Button onAction="#handleXemPhien" styleClass="sidebar-item" text="· View all sessions" />
            <Label styleClass="sidebar-section-title" text="Statistics" />
        </VBox>

        <VBox styleClass="detail-panel" HBox.hgrow="ALWAYS">
            <Label maxWidth="Infinity" styleClass="detail-header" text="Detail" />
            <Separator />

            <HBox spacing="30" style="-fx-padding: 20 20 0 20;" HBox.hgrow="ALWAYS">
                <VBox spacing="12" HBox.hgrow="ALWAYS">
                    <ComboBox fx:id="sanPhamBox" maxWidth="Infinity" onAction="#handleSelectSanPham" promptText="Select product" styleClass="text-field-rounded" />
                    <TextField fx:id="thoiGianMoField" maxWidth="Infinity"
                               promptText="VD: 2025-05-15 20:00"
                               styleClass="text-field-rounded" />

                    <TextField fx:id="thoiGianDongField" maxWidth="Infinity"
                               promptText="VD: 2025-05-15 21:00"
                               styleClass="text-field-rounded" />
                    <TextField fx:id="buocGiaField" maxWidth="Infinity" promptText="Bước giá" styleClass="text-field-rounded" text="bid increment" />
                    <TextArea fx:id="moTaArea" editable="false" maxWidth="Infinity" prefRowCount="5" promptText="Giá khởi điểm + Các mô tả&#10;&#10;Sau khi chọn sản phẩm&#10;-&gt; Hệ thống tự điền các mổ tả còn lại vào đây" styleClass="text-area-rounded" text="Starting price + descriptions&#10;After selecting a product, the system will automatically fill in the descriptions here." wrapText="true" />
                </VBox>
                <Pane fx:id="imgPreviewPane" minWidth="200" prefHeight="240" prefWidth="240" styleClass="image-placeholder" />
            </HBox>

            <Region VBox.vgrow="ALWAYS" />
            <HBox alignment="CENTER_RIGHT" spacing="12" style="-fx-padding: 0 20 16 0;">
                <Button onAction="#handleEdit" styleClass="btn-secondary" text="EDIT" />
                <Button onAction="#handleSave" styleClass="btn-primary" text="SAVE" />
            </HBox>
        </VBox>
    </HBox>
</VBox>
