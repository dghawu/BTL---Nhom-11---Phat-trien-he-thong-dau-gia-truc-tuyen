<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox prefHeight="720" prefWidth="1280" style="-fx-background-color: #FFFFFF;" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.controller.SellerCreateSessionController">

    <HBox styleClass="nav-bar" alignment="CENTER_LEFT">
        <Button text="Home"          styleClass="nav-tab"
                maxWidth="Infinity"  HBox.hgrow="ALWAYS" onAction="#handleHome"/>
        <Button text="Auctions"      styleClass="nav-tab"
                maxWidth="Infinity"  HBox.hgrow="ALWAYS" onAction="#handleAuctions"/>
        <Button text="Seller centre" styleClass="nav-tab-active"
                maxWidth="Infinity"  HBox.hgrow="ALWAYS"/>
        <Button text="Settings"      styleClass="nav-tab"
                maxWidth="Infinity"  HBox.hgrow="ALWAYS" onAction="#handleSettings"/>
    </HBox>

    <HBox VBox.vgrow="ALWAYS">
        <VBox styleClass="sidebar" spacing="4">
            <Label text="Quản lý sản phẩm" styleClass="sidebar-section-title"/>
            <Button text="· Thêm sản phẩm"       styleClass="sidebar-item" onAction="#handleThemSanPham"/>
            <Button text="· Xem tất cả sản phẩm" styleClass="sidebar-item" onAction="#handleXemSanPham"/>
            <Label text="Quản phiên đấu giá" styleClass="sidebar-section-title"/>
            <Button text="· Tạo phiên mới"    styleClass="sidebar-item-active" onAction="#handleTaoPhien"/>
            <Button text="· Xem tất cả phiên" styleClass="sidebar-item"        onAction="#handleXemPhien"/>
            <Label text="Thống kê..." styleClass="sidebar-section-title"/>
        </VBox>

        <VBox HBox.hgrow="ALWAYS" styleClass="detail-panel">
            <Label text="Chi tiết" styleClass="detail-header" maxWidth="Infinity"/>
            <Separator/>

            <HBox spacing="30" style="-fx-padding: 20 20 0 20;" HBox.hgrow="ALWAYS">
                <VBox spacing="12" HBox.hgrow="ALWAYS">
                    <ComboBox fx:id="sanPhamBox" promptText="Chọn sản phẩm"
                              styleClass="text-field-rounded" maxWidth="Infinity" onAction="#handleSelectSanPham"/>
                    <TextField fx:id="thoiGianMoField"   promptText="Thời gian mở phiên"  styleClass="text-field-rounded" maxWidth="Infinity"/>
                    <TextField fx:id="thoiGianDongField" promptText="Thời gian đóng phiên" styleClass="text-field-rounded" maxWidth="Infinity"/>
                    <TextField fx:id="buocGiaField"      promptText="Bước giá"             styleClass="text-field-rounded" maxWidth="Infinity"/>
                    <TextArea  fx:id="moTaArea"
                               promptText="Giá khởi điểm + Các mô tả&#10;&#10;Sau khi chọn sản phẩm&#10;-> Hệ thống tự điền các mổ tả còn lại vào đây"
                               styleClass="text-area-rounded" maxWidth="Infinity" prefRowCount="5"
                               wrapText="true" editable="false"/>
                </VBox>
                <Pane styleClass="image-placeholder" fx:id="imgPreviewPane" prefWidth="240" minWidth="200" prefHeight="240"/>
            </HBox>

            <Region VBox.vgrow="ALWAYS"/>
            <HBox alignment="CENTER_RIGHT" spacing="12" style="-fx-padding: 0 20 16 0;">
                <Button text="EDIT" styleClass="btn-secondary" onAction="#handleEdit"/>
                <Button text="SAVE" styleClass="btn-primary"   onAction="#handleSave"/>
            </HBox>
        </VBox>
    </HBox>
</VBox>
