<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<!-- Screen 1: Login -->

<HBox prefHeight="640" prefWidth="1024" style="-fx-background-color: #FFFFFF;" stylesheets="@../css/style.css" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/25" fx:controller="com.example.controller.LoginController">

    <!-- Left half: decorative / branding space -->
    <Region HBox.hgrow="ALWAYS" />

    <!-- Right half: login form -->
    <VBox alignment="TOP_LEFT" spacing="0" style="-fx-padding: 80 100 0 60;" HBox.hgrow="ALWAYS">

        <!-- Title -->
        <Label style="-fx-font-size: 42px; -fx-font-weight: bold;" styleClass="page-title" stylesheets="@../../../../../server/src/main/resources/css/style.css" text="WELCOME TO..." />

        <Region prefHeight="30" />

        <!-- Subtitle -->
        <Label style="-fx-font-size: 20px; -fx-text-fill: #333333;" stylesheets="@../../../../../server/src/main/resources/css/style.css" text="Log in with your account" />

        <Region prefHeight="16" />

        <!-- Username field -->
        <TextField fx:id="usernameField" maxWidth="500" prefWidth="500" promptText="Username" styleClass="text-field-rounded" stylesheets="@../../../../../server/src/main/resources/css/style.css" />

        <Region prefHeight="10" />

        <!-- Password field -->
        <PasswordField fx:id="passwordField" maxWidth="500" prefWidth="500" promptText="Password" styleClass="text-field-rounded" stylesheets="@../../../../../server/src/main/resources/css/style.css" />

        <Region prefHeight="10" />

        <!-- Login button -->
        <Button fx:id="loginBtn" maxWidth="500" onAction="#handleLogin" prefWidth="500" styleClass="btn-primary" stylesheets="@../../../../../server/src/main/resources/css/style.css" text="LOG IN" />

        <Region prefHeight="6" />

        <!-- Forgot password -->
        <Label style="-fx-font-size: 13px; -fx-font-style: italic; -fx-text-fill: #555555;                       -fx-alignment: CENTER; -fx-max-width: 500;" text="Forgotten your password?" />

        <!-- Error label -->
        <Label fx:id="errorLabel" managed="false" style="-fx-text-fill: #CC0000; -fx-font-size: 12px;" visible="false" />

        <Region prefHeight="30" />

        <!-- Separator -->
        <Label style="-fx-font-size: 18px; -fx-text-fill: #222222;" stylesheets="@../../../../../server/src/main/resources/css/style.css" text="Don't have an account?" />

        <Region prefHeight="12" />

        <!-- Register button -->
        <Button maxWidth="500" onAction="#handleGoRegister" prefWidth="500" styleClass="btn-primary" stylesheets="@../../../../../server/src/main/resources/css/style.css" text="Creat new account" />

    </VBox>
</HBox>
