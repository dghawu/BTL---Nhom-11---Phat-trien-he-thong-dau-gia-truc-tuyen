<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns="http://javafx.com/javafx/26"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.example.controller.LoginController"
           prefWidth="1024"
           prefHeight="640"
           style="-fx-background-color: #FFFFFF;"
           stylesheets="@../css/style.css">

    <VBox alignment="CENTER"
          spacing="0"
          maxWidth="600">

        <!-- TITLE -->
        <Label text="Welcome to"
               maxWidth="Infinity"
               style="
                    -fx-font-family: 'Apple Garamond';
                    -fx-font-size: 60px;
                    -fx-text-fill: #111111;
                    -fx-alignment: CENTER;
               "/>

        <Label text="Online Bidding Platform"
               maxWidth="Infinity"
               style="
                    -fx-font-family: 'Apple Garamond';
                    -fx-font-size: 60px;
                    -fx-text-fill: #111111;
                    -fx-alignment: CENTER;
               "/>

        <Region prefHeight="40"/>

        <!-- LOGIN FORM -->
        <VBox alignment="TOP_LEFT"
              maxWidth="500">

            <Label text="Log in with your account"
                   style="
                    -fx-font-size: 20px;
                    -fx-text-fill: #333333" />

            <Region prefHeight="16"/>

            <TextField fx:id="usernameField"
                       prefWidth="500"
                       maxWidth="500"
                       promptText="Username"
                       style="-fx-background-color: transparent;"
                       styleClass="text-field-rounded"/>

            <Region prefHeight="10"/>

            <PasswordField fx:id="passwordField"
                           prefWidth="500"
                           maxWidth="500"
                           promptText="Password"
                           style="-fx-background-color: transparent;"
                           styleClass="text-field-rounded"/>

            <Region prefHeight="10"/>

            <Button fx:id="loginBtn"
                    text="LOG IN"
                    prefWidth="500"
                    maxWidth="500"
                    onAction="#handleLogin"
                    styleClass="btn-primary"/>

            <Region prefHeight="6"/>

            <Label text="Forgotten your password?"
                   style="
                    -fx-font-size: 13px;
                    -fx-font-style: italic;
                    -fx-text-fill: #555555;" />

            <Label fx:id="errorLabel"
                   visible="false"
                   managed="false"
                   style="
                    -fx-text-fill: #CC0000;
                    -fx-font-size: 12px;
               "/>

            <Region prefHeight="30"/>

            <Label text="Don't have an account?"
                   style="
                    -fx-font-size: 18px;
                    -fx-text-fill: #222222;
               " />

            <Region prefHeight="12"/>

            <Button text="Create new account"
                    prefWidth="500"
                    maxWidth="500"
                    onAction="#handleGoRegister"
                    styleClass="btn-primary"/>

        </VBox>

    </VBox>

</StackPane>