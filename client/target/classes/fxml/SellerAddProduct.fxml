<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox prefHeight="720" prefWidth="1280" style="-fx-background-color: #FFFFFF;" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.controller.SellerCentreController">

    <HBox styleClass="nav-bar" alignment="CENTER_LEFT">
        <Button text="Home"          styleClass="nav-tab"
                maxWidth="Infinity"  HBox.hgrow="ALWAYS" onAction="#handleHome"/>
        <Button text="Auctions"      styleClass="nav-tab"
                maxWidth="Infinity"  HBox.hgrow="ALWAYS" onAction="#handleAuctions"/>
        <Button text="Seller centre" styleClass="nav-tab-active"
                maxWidth="Infinity"  HBox.hgrow="ALWAYS" onAction="#handleSellerCentre"/>
        <Button text="Settings"      styleClass="nav-tab"
                maxWidth="Infinity"  HBox.hgrow="ALWAYS" onAction="#handleSettings"/>
    </HBox>

    <HBox VBox.vgrow="ALWAYS">
        <VBox styleClass="sidebar" spacing="4">
            <Label text="Quản lý sản phẩm" styleClass="sidebar-section-title"/>
            <Button text="· Thêm sản phẩm"       styleClass="sidebar-item-active" onAction="#handleThemSanPham"/>
            <Button text="· Xem tất cả sản phẩm" styleClass="sidebar-item"        onAction="#handleXemSanPham"/>
            <Label text="Quản phiên đấu giá" styleClass="sidebar-section-title"/>
            <Button text="· Tạo phiên mới"       styleClass="sidebar-item"        onAction="#handleTaoPhien"/>
            <Button text="· Xem tất cả phiên"    styleClass="sidebar-item"        onAction="#handleXemPhien"/>
            <Label text="Thống kê..." styleClass="sidebar-section-title" onMouseClicked="#handleThongKe" style="-fx-cursor:hand;"/>
        </VBox>

        <VBox HBox.hgrow="ALWAYS" styleClass="detail-panel">
            <Label text="Chi tiết" styleClass="detail-header" maxWidth="Infinity"/>
            <Separator/>

            <GridPane hgap="20" vgap="14" style="-fx-padding: 20 20 0 20;">
                <columnConstraints>
                    <ColumnConstraints minWidth="120" prefWidth="140"/>
                    <ColumnConstraints hgrow="ALWAYS" minWidth="300"/>
                </columnConstraints>
                <Label text="Tên sản phẩm"  styleClass="detail-label" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                <TextField fx:id="tenField" styleClass="text-field-underline" GridPane.rowIndex="0" GridPane.columnIndex="1" maxWidth="Infinity"/>

                <Label text="Phân loại" styleClass="detail-label" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                <ComboBox fx:id="phanLoaiBox" promptText="Chọn phân loại" styleClass="combo-box-rounded"
                          GridPane.rowIndex="1" GridPane.columnIndex="1" maxWidth="Infinity"/>

                <Label text="Mô tả" styleClass="detail-label" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                <TextField fx:id="moTaField" styleClass="text-field-underline" GridPane.rowIndex="2" GridPane.columnIndex="1" maxWidth="Infinity"/>

                <Label text="Giá khởi điểm" styleClass="detail-label" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                <TextField fx:id="giaField" styleClass="text-field-underline" GridPane.rowIndex="3" GridPane.columnIndex="1" maxWidth="Infinity"/>

                <Label text="Ảnh" styleClass="detail-label" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
            </GridPane>

            <HBox style="-fx-padding: 10 20 0 160;">
                <Pane styleClass="image-placeholder" fx:id="imagePane"
                      prefWidth="240" prefHeight="220" onMouseClicked="#handleChooseImage"/>
            </HBox>

            <Region VBox.vgrow="ALWAYS"/>
            <HBox alignment="CENTER_RIGHT" spacing="12" style="-fx-padding: 0 20 16 0;">
                <Button text="EDIT" styleClass="btn-secondary" onAction="#handleEdit"/>
                <Button text="SAVE" styleClass="btn-primary"   onAction="#handleSave"/>
            </HBox>
        </VBox>
    </HBox>
</VBox>
